<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  App Sandbox is DISABLED for the GitHub-distributed build because the
	  in-app updater needs to:
	    * Process.run('ditto') — fork+exec is blocked under sandbox
	    * Write to /Applications/AWAtv.app — sandbox containers can't
	      reach outside ~/Library/Containers/<bundle-id>/
	    * Process.run('xattr -dr com.apple.quarantine') — drop GK quarantine
	    * Process.run('open -n /Applications/AWAtv.app') — relaunch the
	      freshly-installed copy after the swap
	  Mac App Store requires sandbox=true; this build is NOT for MAS.
	  Sandbox v0.5.1 and earlier blocked the install step silently — that's
	  the bug this entitlement change fixes.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!--
	  Hardened Runtime stays on (set by Xcode/Flutter); these JIT
	  exceptions let media_kit's libmpv compile shader programs at
	  runtime for HW-accelerated playback.
	-->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>

	<!--
	  Even with sandbox off, declare we don't capture audio input so a
	  future entitlement audit is unambiguous.
	-->
	<key>com.apple.security.device.audio-input</key>
	<false/>
</dict>
</plist>
