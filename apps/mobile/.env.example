# AWAtv mobile environment variables
# Copy this file to `.env` and fill in your real keys.

# TMDB v3 API key (get one at https://www.themoviedb.org/settings/api).
TMDB_API_KEY=

# AdMob (use Google's test IDs in development).
# https://developers.google.com/admob/android/test-ads
ADMOB_APP_ID_IOS=ca-app-pub-3940256099942544~1458002511
ADMOB_APP_ID_ANDROID=ca-app-pub-3940256099942544~3347511713
ADMOB_BANNER_IOS=ca-app-pub-3940256099942544/2934735716
ADMOB_BANNER_ANDROID=ca-app-pub-3940256099942544/6300978111
ADMOB_INTERSTITIAL_IOS=ca-app-pub-3940256099942544/4411468910
ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-3940256099942544/1033173712

# RevenueCat (Phase 5)
REVENUECAT_API_KEY_IOS=
REVENUECAT_API_KEY_ANDROID=

# Backend (Supabase) — optional. When BOTH are set, the app initialises
# Supabase and unlocks the magic-link login at /login plus the /account
# screen. When either is blank, the app boots in guest-only mode and the
# /login screen surfaces a "cloud sync isn't configured" banner.
#
# SUPABASE_URL: project URL (e.g. https://abcd1234.supabase.co)
# SUPABASE_ANON_KEY: the anon (public) API key from project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
