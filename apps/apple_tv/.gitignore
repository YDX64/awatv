fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# CocoaPods (not used here, defensive)
Pods/

# Carthage (not used here, defensive)
Carthage/Build/

# Provisioning
*.mobileprovision
*.p12
*.cer
