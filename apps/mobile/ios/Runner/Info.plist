<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Awatv Mobile</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>awatv_mobile</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Premium "background playback" (lock screen, app switcher).
	     `audio` keeps decoding alive while the app is backgrounded so
	     the lock-screen now-playing tile and AirPods controls work.
	     Required by audio_service / audio_session for iOS background
	     audio behaviour. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!--
	  Local-network usage justification surfaced by iOS the first time
	  AWAtv tries to discover an IPTV server or Cast receiver via mDNS.
	  Without this key the discovery socket silently returns zero
	  results on iOS 14+ — the user sees "no servers found" forever.
	-->
	<key>NSLocalNetworkUsageDescription</key>
	<string>AWAtv yerel agindaki IPTV sunucularini ve Cast cihazlarini bulmak icin gerekli.</string>
	<!--
	  Bonjour service types the app discovers / advertises. iOS 14+
	  requires every type to be enumerated here; missing entries are
	  silently filtered out at the framework layer. Order is purely
	  cosmetic but we keep the IPTV-relevant ones first.
	-->
	<key>NSBonjourServices</key>
	<array>
		<string>_xtream._tcp</string>
		<string>_iptv._tcp</string>
		<string>_googlecast._tcp</string>
		<string>_airplay._tcp</string>
	</array>
	<!--
	  Local notifications — used for EPG "Hatirlat" reminders. The
	  string surfaces in the iOS Settings → AWAtv → Notifications
	  panel and is what App Store reviewers expect for transparency
	  even though local notifications technically don't require a
	  usage-description key the way camera / location do.
	-->
	<key>NSUserNotificationsUsageDescription</key>
	<string>AWAtv yakinda baslayacak programlari sana hatirlatabilmek icin yerel bildirim gonderir.</string>
	<!--
	  Voice search — the search bar mic button records the user's
	  voice and converts it to text via the system speech recogniser
	  (SFSpeechRecognizer). iOS surfaces both prompts the first time
	  the mic is tapped; without these strings the request is denied
	  silently and the picker disappears. App Store review explicitly
	  rejects builds that record audio without NSMicrophoneUsageDescription.
	-->
	<key>NSMicrophoneUsageDescription</key>
	<string>AWAtv sesli arama yapabilmen icin mikrofona erisir. Konusman yalnizca arama metnine cevrilir, hicbir yere kaydedilmez.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>AWAtv soyledigin kanal, film ve dizi adlarini metne cevirebilmek icin konusma tanima sistemini kullanir.</string>

	<!--
	  AdMob (Google Mobile Ads SDK) application identifier.
	  Free tier renders a sticky banner on the home screen and an
	  interstitial every Nth playback start. Premium tier suppresses
	  both via the `PremiumFeature.noAds` gate.

	  The default value below is AdMob's universally-recognised TEST
	  app id — it serves real ads with a "Test Ad" watermark and never
	  generates revenue. Replace with your real app id from
	  https://apps.admob.com once you've created the iOS app entry.
	  iOS rejects builds that ship a non-test id without a valid AdMob
	  app, so leave the test id in until prod credentials land.
	-->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-3940256099942544~1458002511</string>

	<!--
	  SKAdNetwork identifiers — Apple's privacy-preserving attribution
	  framework that AdMob (and most ad networks) rely on to measure
	  install conversions on iOS 14+. Without this list the SDK still
	  serves ads but conversion tracking degrades. Pulled from
	  https://developers.google.com/admob/ios/quick-start#update_your_infoplist
	  on 2026-05-04. Update this list when AdMob releases a new mediation
	  partner that needs an additional id.
	-->
	<key>SKAdNetworkItems</key>
	<array>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>cstr6suwn9.skadnetwork</string>
		</dict>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>4fzdc2evr5.skadnetwork</string>
		</dict>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>4pfyvq9l8r.skadnetwork</string>
		</dict>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>2fnua5tdw4.skadnetwork</string>
		</dict>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>ydx93a7ass.skadnetwork</string>
		</dict>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>p78axxw29g.skadnetwork</string>
		</dict>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>v72qych5uu.skadnetwork</string>
		</dict>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>ludvb6z3bs.skadnetwork</string>
		</dict>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>cp8zw746q7.skadnetwork</string>
		</dict>
	</array>

	<!--
	  ATT (App Tracking Transparency) prompt copy — required by Apple
	  for iOS 14.5+ to show the IDFA permission dialog. The SDK shows
	  this once and remembers the user's choice; granting unlocks
	  personalised ads (better eCPM), denying falls back to contextual.
	-->
	<key>NSUserTrackingUsageDescription</key>
	<string>AWAtv reklamlari sana daha alakali gostermek icin bu izni ister. Reddetsen bile uygulama calisir; sadece reklamlar daha az hedeflenmis olur.</string>
</dict>
</plist>
