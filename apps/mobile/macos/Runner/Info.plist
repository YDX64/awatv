<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconFile</key>
	<string></string>
	<key>CFBundleIdentifier</key>
	<string>com.awatv.mobile</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>AWAtv</string>
	<key>CFBundleDisplayName</key>
	<string>AWAtv</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<!--
	  Flutter pipes pubspec.yaml's `version: x.y.z+build` into these via
	  Flutter-Generated.xcconfig at build time. Without the placeholders,
	  the bundle would ship a frozen `0.2.0` from project init day, which
	  caused v0.5.x users to get stuck in an infinite "yeni sürüm var"
	  loop because PackageInfo.version reported 0.2.0 against a 0.5.x
	  manifest forever. See `flutter build macos --build-name`.
	-->
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.entertainment</string>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright (C) 2026 AWA Digital Interactive. All rights reserved.</string>
	<key>NSMainNibFile</key>
	<string>MainMenu</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
</dict>
</plist>
